local Services = {
	CoreGui = game:GetService('CoreGui'),
	Players = game:GetService('Players'),
	HttpService = game:GetService('HttpService'),
	TweenService = game:GetService('TweenService')
}

local Configs = {}

Configs.Colours = {}
Configs.Colours.SectionGradient = ColorSequence.new({ColorSequenceKeypoint.new(0, Color3.fromRGB(24, 24, 24)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(81, 97, 243)), ColorSequenceKeypoint.new(1, Color3.fromRGB(24, 24, 24))})
Configs.Colours.Selected = Color3.fromRGB(81, 97, 243)
Configs.Colours.UnSelected = Color3.fromRGB(100, 100, 100)

local PrivateLib = {}

function PrivateLib.Create(Class, Properties, Parent)
	local Object = Instance.new(Class)

	for Property, Value in Properties do Object[Property] = Value end
	if Parent then Object.Parent = Parent end

	return Object
end

local Library = {}

function Library.new (Name)

	print('Started'.. Name)

	local ToReturn = {}
	ToReturn.ScreenUI = PrivateLib.Create('ScreenGui', {Name = Services.HttpService:GenerateGUID(false), ZIndexBehavior = Enum.ZIndexBehavior.Sibling}, Services.Players.LocalPlayer.PlayerGui)
	PrivateLib.Create('StringValue', {Name = 'MADE BY PizzaMuncher42 ON GITHUB', Value = Name}, ToReturn.ScreenUI)
	ToReturn.Frames = {}

	ToReturn.Frames.Main = PrivateLib.Create('ImageLabel', {Image = 'http://www.roblox.com/asset/?id=7300333488', Size = UDim2.new(0.6, 0, 0.6, 0), Position = UDim2.new(0.5, 0, 0.5, 0), AnchorPoint = Vector2.new(0.5, 0.5)}, ToReturn.ScreenUI)
	PrivateLib.Create('UIAspectRatioConstraint', {AspectRatio = 1.4}, ToReturn.Frames.Main)
	PrivateLib.Create('UIDragDetector', {}, ToReturn.Frames.Main)

	ToReturn.Frames.Title = PrivateLib.Create('TextLabel', {Size = UDim2.new(0.956, 0, 0.032, 0), Position = UDim2.new(0.5, 0, 0.03, 0), AnchorPoint = Vector2.new(0.5, 0.5), BackgroundTransparency = 1, TextColor3 = Color3.new(1, 1, 1), TextSize = 14, Font = Enum.Font.Ubuntu, TextXAlignment = Enum.TextXAlignment.Left, Text = Name}, ToReturn.Frames.Main)

	ToReturn.Frames.Tabs = PrivateLib.Create('Frame', {Size = UDim2.new(0.109, 0, 0.894, 0), Position = UDim2.new(0.017, 0, 0.082, 0), BackgroundTransparency = 1}, ToReturn.Frames.Main)
	PrivateLib.Create('UIListLayout', {HorizontalAlignment = Enum.HorizontalAlignment.Center, VerticalAlignment = Enum.VerticalAlignment.Center}, ToReturn.Frames.Tabs)
	ToReturn.Frames.DisplayTab = PrivateLib.Create('Frame', {Size = UDim2.new(0.837, 0, 0.892, 0), Position = UDim2.new(0.146, 0, 0.084, 0), BackgroundTransparency = 1}, ToReturn.Frames.Main)

	ToReturn.Frames.SectionTabs = PrivateLib.Create('Frame', {Size = UDim2.new(1, 0, 0.056, 0), BackgroundTransparency = 1}, ToReturn.Frames.DisplayTab)
	PrivateLib.Create('UIListLayout', {FillDirection = Enum.FillDirection.Horizontal, SortOrder = Enum.SortOrder.Name}, ToReturn.Frames.SectionTabs)
	
	ToReturn.Functions = {}
	ToReturn.Tabs = {Amount = 0, Selected = 1, Frames = {Tabs = {}, Displays = {}}}
	
	function ToReturn.Functions.AddTab (Variable, Media)
		
		ToReturn.Tabs.Amount += 1
		local Id = ToReturn.Tabs.Amount
		local Tab = {}
		local Sections = {Amount = 0, Selected = 1, Frames = {Sections = {}, Displays = {}}}
		if Media == 'Image' then Tab.Button = PrivateLib.Create('ImageButton', {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Image = Variable}, ToReturn.Frames.Tabs)
		elseif Media == 'Text' then Tab.Button = PrivateLib.Create('TextButton', {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Font = Enum.Font.Ubuntu, TextScaled = true, Text = Variable}, ToReturn.Frames.Tabs) end
		PrivateLib.Create('UIAspectRatioConstraint', {}, Tab.Button)
		
		local Display = {}
		Display.TabDisplay = PrivateLib.Create('CanvasGroup', {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1}, ToReturn.Frames.DisplayTab)
		Display.SectionTab = PrivateLib.Create('Frame', {Size = UDim2.new(1, 0, 0.056, 0), BackgroundTransparency = 1}, Display.TabDisplay)
		PrivateLib.Create('UIListLayout', {FillDirection = Enum.FillDirection.Horizontal}, Display.SectionTab)
		
		ToReturn.Tabs.Frames.Tabs[Id] = Tab
		ToReturn.Tabs.Frames.Displays[Id] = Display
		
		if Id == ToReturn.Tabs.Selected and Media == 'Text' then
			Display.TabDisplay.Visible = true
			if Media == 'Text' then Tab.Button.TextColor3 = Configs.Colours.Selected
			elseif Media == 'Image' then Tab.Button.ImageColor3 = Configs.Colours.Selected end
		else
			Display.TabDisplay.Visible = false
			if Media == 'Text' then Tab.Button.TextColor3 = Configs.Colours.UnSelected
			elseif Media == 'Image' then Tab.Button.ImageColor3 = Configs.Colours.UnSelected end
		end
		
		Tab.Functions = {}
		
		function Tab.Functions.AddSection (SubTitle)
			
			Sections.Amount += 1
			local SId = Sections.Amount
			local SSection = {}
			SSection.Button = PrivateLib.Create('TextButton', {BackgroundTransparency = 1, TextSize = 16, Name = SId, Font = Enum.Font.Ubuntu, Text = SubTitle}, Display.SectionTab)
			SSection.Indicator = PrivateLib.Create('Frame', {Size = UDim2.new(1, 0, 0, 1), Position = UDim2.new(0, 0, 1.1, 0), BackgroundColor3 = Color3.new(1, 1, 1), BorderSizePixel = 0}, SSection.Button)

			local SDisplay = {}
			SDisplay.Main = PrivateLib.Create('CanvasGroup', {Size = UDim2.new(1, 0, 0.9, 0), Position = UDim2.new(0, 0, 1, 0), AnchorPoint = Vector2.new(0, 1), BackgroundTransparency = 1}, Display.TabDisplay)
			SDisplay.Left = PrivateLib.Create('Frame', {Size = UDim2.new(0.5, 0, 1, 0), Transparency = 1}, SDisplay.Main)
			PrivateLib.Create('UIListLayout', {HorizontalAlignment = Enum.HorizontalAlignment.Center}, SDisplay.Left)
			SDisplay.Right = PrivateLib.Create('Frame', {Size = UDim2.new(0.5, 0, 1, 0), Position = UDim2.new(1, 0, 0, 0), AnchorPoint = Vector2.new(1, 0), Transparency = 1}, Display.Main)
			PrivateLib.Create('UIListLayout', {HorizontalAlignment = Enum.HorizontalAlignment.Center}, SDisplay.Right)

			PrivateLib.Create('UIGradient', {Color = Configs.Colours.SectionGradient}, SSection.Indicator)

			Sections.Frames.Sections[SId] = SSection
			Sections.Frames.Displays[SId] = SDisplay

			for _, CSection in pairs(Sections.Frames.Sections) do CSection.Button.Size = UDim2.new(1/Sections.Amount, 0, 1, 0) end

			if SId == Sections.Selected then SSection.Button.TextColor3 = Configs.Colours.Selected; SSection.Indicator.Transparency = 0 else
				SSection.Button.TextColor3 = Configs.Colours.UnSelected; SSection.Indicator.Transparency = 1 end


			SSection.Button.MouseButton1Down:Connect(function()

				Sections.Selected = SId

				for Number = 1,Sections.Amount do

					local SSection = Sections.Frames.Sections[Number].Button
					local Indicator = Sections.Frames.Sections[Number].Indicator
					local CDisplay = Sections.Frames.Displays[Number].Main

					if Number ~= SId then

						Services.TweenService:Create(SSection, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Configs.Colours.UnSelected}):Play()
						Services.TweenService:Create(Indicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 1}):Play()
						Services.TweenService:Create(CDisplay, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 1}):Play()
						task.delay(0.2, function() CDisplay.Visible = false end)

					else

						CDisplay.Visible = true
						Services.TweenService:Create(SSection, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Configs.Colours.Selected}):Play()
						Services.TweenService:Create(Indicator, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundTransparency = 0}):Play()
						Services.TweenService:Create(CDisplay, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 0}):Play()

					end
				end
			end)
		end
		
		Tab.Button.MouseButton1Down:Connect(function()
			
			print('Clicked')
			
			ToReturn.Tabs.Selected = Id
			
			for Number = 1,ToReturn.Tabs.Amount do

				local Tab = ToReturn.Tabs.Frames.Tabs[Number].Button
				local Display = ToReturn.Tabs.Frames.Displays[Number].TabDisplay

				if Number ~= Id then

					if Tab:IsA('TextButton') then Services.TweenService:Create(Tab, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Configs.Colours.UnSelected}):Play()
					elseif Tab:IsA('ImageButton') then Services.TweenService:Create(Tab, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {ImageColor3 = Configs.Colours.UnSelected}):Play() end
					
					Services.TweenService:Create(Display, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 1}):Play()
					task.delay(0.2, function() Display.Visible = false end)

				else

					if Tab:IsA('TextButton') then Services.TweenService:Create(Tab, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {TextColor3 = Configs.Colours.Selected}):Play()
					elseif Tab:IsA('ImageButton') then Services.TweenService:Create(Tab, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {ImageColor3 = Configs.Colours.Selected}):Play() end
					
					Display.Visible = true
					Services.TweenService:Create(Display, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 0}):Play()

				end
			end
		end)
		
		return Tab
	end
	return ToReturn
end

return Library
